    <Compile Include="..\std\no-runtime\shared\Runtime\Delegate.cs" Link="src\Std\Runtime\Delegate.cs" />
    <Compile Include="..\std\no-runtime\shared\Runtime\MulticastDelegate.cs" Link="src\Std\Runtime\MulticastDelegate.cs" />
