    <Compile Include="..\std\no-runtime\shared\GC\GcMark.cs" Link="src\Std\GC\GcMark.cs" />
    <Compile Include="..\std\no-runtime\shared\GC\GcSweep.cs" Link="src\Std\GC\GcSweep.cs" />
    <Compile Include="..\std\no-runtime\shared\GC\GcRoots.cs" Link="src\Std\GC\GcRoots.cs" />
    <Compile Include="..\std\no-runtime\shared\GC\GC.cs" Link="src\Std\GC\GC.cs" />
    <Compile Include="..\std\no-runtime\shared\Bcl\Guid.cs" Link="src\Std\Bcl\Guid.cs" />
    <Compile Include="..\std\no-runtime\shared\Bcl\Path.cs" Link="src\Std\Bcl\Path.cs" />
    <Compile Include="..\std\no-runtime\shared\Bcl\Interfaces.cs" Link="src\Std\Bcl\Interfaces.cs" />
    <Compile Include="..\std\no-runtime\shared\Bcl\DebuggerAttributes.cs" Link="src\Std\Bcl\DebuggerAttributes.cs" />
    <Compile Include="..\std\no-runtime\shared\Bcl\EqualityComparer.cs" Link="src\Std\Bcl\EqualityComparer.cs" />
    <Compile Include="..\std\no-runtime\shared\Bcl\Comparer.cs" Link="src\Std\Bcl\Comparer.cs" />
    <Compile Include="..\std\no-runtime\shared\Bcl\List.cs" Link="src\Std\Bcl\List.cs" />
    <Compile Include="..\std\no-runtime\shared\Bcl\Dictionary.cs" Link="src\Std\Bcl\Dictionary.cs" />
    <Compile Include="..\std\no-runtime\shared\Bcl\HashSet.cs" Link="src\Std\Bcl\HashSet.cs" />
    <Compile Include="..\std\no-runtime\shared\Bcl\Stack.cs" Link="src\Std\Bcl\Stack.cs" />
